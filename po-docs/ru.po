msgid "B<--timezone> TIMEZONE (see C<customize> below)"
msgstr "B<--timezone> ЧАСОВОЙ_ПОЯС (см. C<customize> ниже)"

#. type: =item
#: sysprep/sysprep-extra-options.pod:467
