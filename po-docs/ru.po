#. type: textblock
#: align/virt-alignment-scan.pod:140 cat/virt-cat.pod:92
#: customize/virt-customize.pod:100 df/virt-df.pod:118
#: drivers/virt-drivers.pod:168 edit/virt-edit.pod:109
