msgstr "B<--truncate-recursive> ПУТЬ (см. C<customize> ниже)"

#. type: =item
#: sysprep/sysprep-extra-options.pod:483
msgid "B<--uninstall> PKG,PKG..  (see C<customize> below)"
msgstr "B<--uninstall> ПАКЕТ,ПАКЕТ..  (см. C<customize> ниже)"

