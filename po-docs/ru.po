msgstr "B<--update> (см. C<customize> ниже)"

#. type: =item
#: sysprep/sysprep-extra-options.pod:502
msgid "B<--upload> FILE:DEST (see C<customize> below)"
msgstr "B<--upload> ФАЙЛ:ЦЕЛЬ (см. C<customize> ниже)"

#. type: =item
