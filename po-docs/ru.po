msgstr "B<--touch> ФАЙЛ (см. C<customize> ниже)"

#. type: =item
#: sysprep/sysprep-extra-options.pod:472
msgid "B<--truncate> FILE (see C<customize> below)"
msgstr "B<--truncate> ФАЙЛ (см. C<customize> ниже)"

#. type: =item
#: sysprep/sysprep-extra-options.pod:478
